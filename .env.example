# Telegram bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token-here

# Your NakoPay merchant key. Required.
# Create one at https://nakopay.com/dashboard/api-keys
# Use sk_test_... for test mode and sk_live_... for production.
NAKOPAY_API_KEY=sk_test_replace_me

# NakoPay API base URL. Defaults to the canonical hosted endpoint.
# Override only if you self-host the NakoPay edge functions.
NAKOPAY_API_BASE=https://daslrxpkbkqrbnjwouiq.supabase.co/functions/v1

# Long-poll timeout in seconds (Telegram getUpdates).
TELEGRAM_POLL_TIMEOUT=30
